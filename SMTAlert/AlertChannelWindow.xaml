<Window x:Class="SMTAlert.AlertChannelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AlertCh_Title}" Height="500" Width="600"
        WindowStartupLocation="CenterScreen" Background="#FF232223">
    <Grid Background="#FF232223" Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
            <Label Content="{DynamicResource AlertCh_Channel}" Foreground="White" />
            <Label x:Name="ChannelNameLabel" Foreground="#FF5588FF" FontWeight="Bold" />
            <Label Content="{DynamicResource AlertCh_ClearKeywords}" Foreground="Gray" Margin="20,0,0,0" />
            <Label x:Name="ClearKeywordsLabel" Foreground="#FFFF8844" />
        </StackPanel>

        <ListBox x:Name="MessageListBox" Grid.Row="1"
                 Background="#FF1A1A1A" Foreground="White"
                 BorderBrush="#FF444444" BorderThickness="1"
                 VirtualizingPanel.ScrollUnit="Pixel" />
    </Grid>
</Window>
